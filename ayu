name: Revisar BOE y BOJA - ayudas sociales

on:
  schedule:
    - cron: "30 6 * * *"
  workflow_dispatch:
    inputs:
      date:
        description: "Fecha a revisar en formato YYYY-MM-DD. Si se deja vacia, usa hoy en Europe/Madrid."
        required: false
        type: string
      days:
        description: "Numero de dias hacia atras que quieres revisar, incluyendo la fecha indicada."
        required: false
        default: "10"
        type: string

permissions:
  contents: write

jobs:
  revisar:
    runs-on: ubuntu-latest
    env:
      RUN_DATE: ${{ github.event.inputs.date || '' }}
      RUN_DAYS: ${{ github.event.inputs.days || '10' }}

    steps:
      - name: Descargar repositorio
        uses: actions/checkout@v4

      - name: Preparar Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - name: Revisar BOE y BOJA
        run: |
          if [ -n "$RUN_DATE" ]; then
            python scraper_boe_boja_social.py --date "$RUN_DATE" --days "$RUN_DAYS"
          else
            python scraper_boe_boja_social.py --days "$RUN_DAYS"
          fi

      - name: Guardar resultados en el repositorio
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "41898282+github-actions[bot]@users.noreply.github.com"
          git add informes_boe_boja_social/
          if git diff --cached --quiet; then
            echo "No hay cambios que guardar."
          else
            git commit -m "Actualizar ayudas sociales BOE/BOJA"
            git push
          fi
